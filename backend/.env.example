# ═══════════════════════════════════════════════════════════
#  NextLab Backend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env

# ── Database ──────────────────────────────────────────────
# IMPORTANT: Use the Supabase Connection Pooler URL (IPv4).
# Find it in: Supabase → Settings → Database → Connection Pooling
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-xx-xxxx.pooler.supabase.com:6543/postgres"

# ── Supabase JWT Secret ───────────────────────────────────
# Required to verify user tokens on protected endpoints.
# Find it in: Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ── Redis / Celery Broker ─────────────────────────────────
# Upstash Redis or any Redis instance (use rediss:// for TLS)
REDIS_URL="rediss://default:xxxxx@xxx.upstash.io:6379"

# ── Frontend URL (CORS allow-list) ────────────────────────
FRONTEND_URL="https://your-app.vercel.app"
CORS_EXTRA_ORIGINS="http://localhost:3000"

# ── External APIs ─────────────────────────────────────────
GROQ_API_KEY=""
SHODAN_API_KEY=""

# ── AI Model ──────────────────────────────────────────────
AI_MODEL="llama-3.3-70b-versatile"

# ── Rate Limiting ─────────────────────────────────────────
FREE_SCAN_RATE_LIMIT=10
