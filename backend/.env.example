# Database (Supabase PostgreSQL — use Transaction connection string)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Queue / Message Broker (Upstash Serverless Redis — requires rediss:// TLS)
REDIS_URL="rediss://default:[YOUR-PASSWORD]@[YOUR-UPSTASH-ENDPOINT].upstash.io:[PORT]"

# Frontend URL (for CORS and Stripe redirects)
FRONTEND_URL="https://your-domain.vercel.app"

# Additional CORS origins (comma-separated)
CORS_EXTRA_ORIGINS="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# External APIs
SHODAN_API_KEY=""
GROQ_API_KEY=""

# AI Model (Groq-supported model)
AI_MODEL="llama-3.3-70b-versatile"

# Rate Limiting
FREE_SCAN_RATE_LIMIT=10

# PDF Reports directory (defaults to /tmp/reports)
# REPORTS_DIR="/tmp/reports"
