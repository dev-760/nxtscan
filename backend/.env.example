# Database (Supabase PostgreSQL Connection Details)
# Transaction connection string is recommended for backend usage
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Queue / Message Broker (Upstash Serverless Redis)
# Format typically requires 'rediss://' (with strict SSL TLS)
REDIS_URL="rediss://default:[YOUR-PASSWORD]@[YOUR-UPSTASH-ENDPOINT].upstash.io:[PORT]"

# APIs
SHODAN_API_KEY=""
SECURITYTRAILS_API_KEY=""
GROQ_API_KEY=""
