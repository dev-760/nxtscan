# ═══════════════════════════════════════════════════════════
#  NextLab — Git Ignore
# ═══════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────
.env
.env.local
.env.production
.env*.local

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
venv/
.venv/
*.egg-info/
dist/
build/

# ── Node.js ───────────────────────────────────────────────
node_modules/
.next/
out/

# ── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Reports & Temp ────────────────────────────────────────
/tmp/reports/
*.pdf

# ── Vercel ────────────────────────────────────────────────
.vercel/
